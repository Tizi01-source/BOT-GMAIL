# ═══════════════════════════════════════════════════════════════
# 🔐 CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ═══════════════════════════════════════════════════════════════
# 
# INSTRUCCIONES:
# 1. Copia este archivo a .env (no subir a git)
# 2. Reemplaza los valores con tus credenciales reales
# 3. Las rutas son relativas a la raíz del proyecto
#
# ⚠️  NUNCA comitees este archivo con valores reales
# ⚠️  Está en .gitignore por seguridad
#

# ─────────────────────────────────────────────────────────────
# GMAIL OAUTH2 (Credenciales de Google Cloud)
# ─────────────────────────────────────────────────────────────
# Descargables desde: https://console.cloud.google.com/apis/credentials
# Tipo: OAuth 2.0 Client IDs (Desktop App)

# Ruta al archivo credenciales.json (descargado de Google Cloud Console)
# Por defecto en la raíz del proyecto
GMAIL_CREDENTIALS_PATH=./credenciales.json

# Ruta donde se guarda token.json (se genera automáticamente)
# Contiene access_token y refresh_token tras autenticación
GMAIL_TOKEN_PATH=./token.json

# Redirect URI configurado en Google Cloud Console
# DEBE coincidir exactamente con lo configurado en OAuth Consent Screen
GMAIL_REDIRECT_URI=http://localhost:3000

# Query de búsqueda en Gmail (emails no leídos con asunto "Solicitud")
# Modifica según tus necesidades
GMAIL_SEARCH_QUERY=is:unread subject:Solicitud

# Intervalo de polling en milisegundos (5 minutos = 300000 ms)
GMAIL_POLLING_INTERVAL=300000

# ─────────────────────────────────────────────────────────────
# GOOGLE GENERATIVE AI (Gemini)
# ─────────────────────────────────────────────────────────────
# Obtén tu API Key desde: https://aistudio.google.com/app/apikey
# O desde Google Cloud Console si usas proyecto empresarial

# API Key para Generative AI / Gemini
# CRÍTICO: Nunca la publiques ni hagas push a GitHub
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Modelo de Gemini a usar (recomendado: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────────────────────
# BASE DE DATOS / EXCEL
# ─────────────────────────────────────────────────────────────

# Ruta al archivo de socios en Excel (.xlsx)
# Debe tener columnas: DNI, Nombre, Estado, Deuda
EXCEL_SOCIOS_PATH=./datos/socios.xlsx

# Ruta opcional para registrar movimientos/créditos otorgados
EXCEL_MOVIMIENTOS_PATH=./datos/movimientos.xlsx

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE CUPOS Y REGLAS DE NEGOCIO
# ─────────────────────────────────────────────────────────────

# Sueldo mínimo requerido para otorgar crédito (en guaraníes)
CUPO_SUELDO_MINIMO=50000

# Porcentaje del sueldo a usar para calcular base de cupo
CUPO_PORCENTAJE_BASE=30

# Cupo máximo para socio NUEVO (en guaraníes)
CUPO_MAXIMO_NUEVO=150000

# Cupo máximo para socio ACTIVO (en guaraníes)
CUPO_MAXIMO_ACTIVO=500000

# Descuento aplicado si el socio tiene deuda (0.5 = 50% del cupo)
CUPO_DESCUENTO_DEUDA=0.5

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE EMAILS Y RESPUESTAS
# ─────────────────────────────────────────────────────────────

# Dirección de email de contacto para errores/soporte
EMAIL_SOPORTE=soporte@cooperativa.com

# Remitente de emails automáticos (usualmente tu cuenta de Gmail)
EMAIL_REMITENTE=bot@cooperativa.com

# ─────────────────────────────────────────────────────────────
# MODOS DE OPERACIÓN Y DEBUG
# ─────────────────────────────────────────────────────────────

# Modo debug: mostrar logs detallados (true/false)
DEBUG=false

# Modo dry-run: simular sin enviar emails reales (true/false)
DRY_RUN=false

# Máximo de correos a procesar en una ejecución
MAX_EMAILS_POR_EJECUCION=20

# ─────────────────────────────────────────────────────────────
# APLICAR CAMBIOS
# ─────────────────────────────────────────────────────────────
# Después de configurar este archivo:
# 1. Renombra a .env (sin .example)
# 2. Ejecuta: npm install
# 3. Ejecuta: npx ts-node src/diagnose.ts
